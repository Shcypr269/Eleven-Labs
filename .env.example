# CallPilot - India-First Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# TELEPHONY (Choose One: Exotel for India or Twilio for International)
# =============================================================================

# Exotel (Recommended for India - TRAI compliant, <50ms latency)
# Get credentials: https://exotel.com/
EXOTEL_ACCOUNT_SID=your_exotel_account_sid
EXOTEL_AUTH_TOKEN=your_exotel_auth_token
EXOTEL_EXOPHONE=+911234567890

# Twilio (International fallback)
# Get credentials: https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# VOICE AI (Choose One: ElevenLabs or Gnani.ai for Indian voices)
# =============================================================================

# ElevenLabs (Global, high quality)
# Get API key: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=Rachel

# Gnani.ai (India-first, better Hindi/regional language support)
# Get API key: https://gnani.ai/
GNANI_API_KEY=your_gnani_api_key

# =============================================================================
# SPEECH-TO-TEXT (Deepgram recommended for Hinglish)
# =============================================================================

# Deepgram (Best for Indian accents and Hinglish)
# Get API key: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key

# OpenAI Whisper (Fallback option)
OPENAI_API_KEY=your_openai_api_key

# =============================================================================
# DND COMPLIANCE (TRAI Do Not Disturb)
# =============================================================================

# TRAI DND API for compliance checking
# Get API key: https://main.trai.gov.in/
TRAI_DND_API_KEY=your_trai_dnd_api_key

# =============================================================================
# GOOGLE APIs (Places, Maps, Calendar)
# =============================================================================

# Google Maps Platform (for Places API)
# Get API key: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google Calendar API (for appointment booking)
# Download credentials from Google Cloud Console
GOOGLE_APPLICATION_CREDENTIALS=path/to/credentials.json

# =============================================================================
# REDIS (For distributed swarm calling)
# =============================================================================

# Redis connection string
REDIS_URL=redis://localhost:6379

# =============================================================================
# DATABASE (PostgreSQL with pgvector for RAG)
# =============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://callpilot:password@localhost:5432/callpilot

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# FastAPI server
HOST=0.0.0.0
PORT=8000

# WebSocket voice streaming
ENABLE_WEBSOCKET=true
WEBSOCKET_PORT=8765

# =============================================================================
# VISION/OCR (For extracting info from provider images)
# =============================================================================

# Tesseract OCR data path
# Windows: C:\Program Files\Tesseract-OCR\tessdata
# Linux: /usr/share/tessdata
TESSDATA_PATH=C:\Program Files\Tesseract-OCR\tessdata

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

LOG_LEVEL=INFO
LOG_FILE=callpilot.log

# =============================================================================
# INDIA-SPECIFIC SETTINGS
# =============================================================================

# Default location (KIIT Bhubaneswar)
DEFAULT_LAT=20.35
DEFAULT_LNG=85.82

# Timezone
TIMEZONE=Asia/Kolkata

# Currency
CURRENCY=INR

# Language preferences (for Hinglish detection)
PRIMARY_LANGUAGE=en-IN
SECONDARY_LANGUAGE=hi
